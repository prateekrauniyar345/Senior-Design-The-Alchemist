# API base URL for the FastAPI backend (no trailing slash)
VITE_API_URL=http://localhost:8001

# Supabase: required for OAuth (Google / Microsoft). Get from Supabase dashboard → Settings → API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# When true, app calls logout on every load so refresh always shows login screen.
VITE_FORCE_LOGOUT_ON_LOAD=true
